{
	"name": "@agentos-software/pi",
	"version": "0.0.1",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"pi": "./node_modules/@earendil-works/pi-coding-agent/dist/cli.js",
		"pi-acp": "./dist/pi-acp/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/package",
		"!dist/package.tar",
		"!dist/package.aospkg",
		"agentos-package.json"
	],
	"scripts": {
		"build": "rm -rf dist && node scripts/build-pi-acp.mjs && tsc && agentos-toolchain pack . --out dist/package --agent pi-acp --prune-native --omit-optional",
		"check-types": "tsc --noEmit",
		"test": "pnpm build && node --test --test-force-exit tests/*.test.mjs"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "1.2.1",
		"@earendil-works/pi-coding-agent": "0.80.6",
		"pi-mcp-adapter": "2.11.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@agentos-software/manifest": "workspace:*",
		"@rivet-dev/agentos-toolchain": "workspace:*",
		"@types/node": "^22.10.2",
		"typescript": "^5.7.2"
	}
}
