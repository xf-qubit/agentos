{
	"name": "@agentos-software/claude-code",
	"version": "0.0.1",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"claude": "./dist/claude-cli.mjs",
		"claude-agent-acp": "./dist/adapter.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/package",
		"!dist/package.tar",
		"!dist/package.aospkg",
		"agentos-package.json"
	],
	"scripts": {
		"build": "rm -rf dist && tsc && node ./scripts/stage-upstream-cli.mjs && agentos-toolchain pack . --out dist/package --agent claude-agent-acp --prune-native --omit-optional",
		"check-types": "tsc --noEmit",
		"test": "pnpm build && node --test --test-force-exit tests/*.test.mjs"
	},
	"dependencies": {
		"@agentclientprotocol/claude-agent-acp": "0.29.2",
		"@anthropic-ai/sdk": "0.111.0",
		"@anthropic-ai/claude-agent-sdk": "0.2.112"
	},
	"devDependencies": {
		"@agentclientprotocol/sdk": "1.2.1",
		"@agentos-software/manifest": "workspace:*",
		"@copilotkit/llmock": "^1.6.0",
		"@rivet-dev/agentos-toolchain": "workspace:*",
		"@types/node": "^22.10.2",
		"typescript": "^5.7.2"
	}
}
