{
  "name": "claude",
  "agent": {
    "acpEntrypoint": "claude-agent-acp",
    "env": {
      "CLAUDE_CODE_EXECUTABLE": "/opt/agentos/bin/claude",
      "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
      "CLAUDE_CODE_SHELL": "/bin/sh",
      "DISABLE_TELEMETRY": "1",
      "SHELL": "/bin/sh",
      "USE_BUILTIN_RIPGREP": "0"
    }
  },
  "registry": {
    "slug": "claude-code",
    "title": "Claude Code",
    "description": "Run Claude Code as an agentOS agent with full tool access, file editing, and shell execution.",
    "beta": true,
    "docsHref": "/docs/agents/claude",
    "image": "/images/registry/claude-code.svg",
    "category": "agents",
    "priority": 90
  }
}
