+#[link(wasm_import_module = "host_process")]
+unsafe extern "C" {
+    fn proc_spawn_v3(
+        exec_path_ptr: *const u8,
+        exec_path_len: u32,
+        argv_ptr: *const u8,
+        argv_len: u32,
+        envp_ptr: *const u8,
+        envp_len: u32,
+        actions_ptr: *const u8,
+        actions_len: u32,
+        cwd_ptr: *const u8,
+        cwd_len: u32,
+        attr_flags: u32,
+        sigdefault_lo: u32,
+        sigdefault_hi: u32,
+        sigmask_lo: u32,
+        sigmask_hi: u32,
+        pgroup: u32,
+        ret_pid: *mut u32,
+    ) -> u32;
+
+    fn proc_signal_mask_v2(
+        how: u32,
+        set_lo: u32,
+        set_hi: u32,
+        ret_old_lo: *mut u32,
+        ret_old_hi: *mut u32,
+    ) -> u32;
+
+    fn proc_exec(
+        exec_path_ptr: *const u8,
+        exec_path_len: u32,
+        argv_ptr: *const u8,
+        argv_len: u32,
+        envp_ptr: *const u8,
+        envp_len: u32,
+        cloexec_fds_ptr: *const u32,
+        cloexec_fds_len: u32,
+    ) -> u32;
+
+    fn proc_fexec(
+        exec_fd: u32,
+        argv_ptr: *const u8,
+        argv_len: u32,
+        envp_ptr: *const u8,
+        envp_len: u32,
+        cloexec_fds_ptr: *const u32,
+        cloexec_fds_len: u32,
+    ) -> u32;
+
+    fn proc_waitpid_v2(
+        pid: u32,
+        options: u32,
+        ret_exit_code: *mut u32,
+        ret_signal: *mut u32,
+        ret_pid: *mut u32,
+        ret_core_dumped: *mut u32,
+    ) -> u32;
+
+    fn proc_kill(pid: u32, signal: u32) -> u32;
+
+    fn fd_pipe(ret_read_fd: *mut u32, ret_write_fd: *mut u32) -> u32;
+    fn fd_setfd(fd: u32, flags: u32) -> u32;
+}
+
+/// Convert a WASI errno to an io::Error.
+fn wasi_err(errno: u32) -> io::Error {
+    io::Error::from_raw_os_error(errno as i32)
+}
+
+const FDOP_CLOSE: u32 = 1;
+const FDOP_DUP2: u32 = 2;
+const FDOP_OPEN: u32 = 3;
+const O_WRONLY: u32 = 1;
+
+fn append_spawn_action(
+    actions: &mut Vec<u8>,
+    command: u32,
+    fd: u32,
+    source_fd: u32,
+    open_flags: u32,
+    path: &[u8],
+) {
+    for value in [command, fd, source_fd, open_flags, 0, path.len() as u32] {
+        actions.extend_from_slice(&value.to_le_bytes());
+    }
+    actions.extend_from_slice(path);
+}
+
+fn append_stdio_action(actions: &mut Vec<u8>, source_fd: u32, target_fd: u32) {
+    if source_fd == u32::MAX {
+        let open_flags = if target_fd == 0 { 0 } else { O_WRONLY };
+        append_spawn_action(actions, FDOP_OPEN, target_fd, 0, open_flags, b"/dev/null");
+    } else {
+        append_spawn_action(actions, FDOP_DUP2, target_fd, source_fd, 0, &[]);
+    }
+}
+
+/// Encode separate host termination fields into POSIX wait-status bits expected by ExitStatus.
+fn encode_wait_status(exit_code: u32, signal: u32, core_dumped: u32) -> i32 {
+    if signal != 0 {
+        ((signal & 0x7f) | if core_dumped != 0 { 0x80 } else { 0 }) as i32
+    } else {
+        ((exit_code & 0xff) << 8) as i32
+    }
+}
+
+/// Create a pipe, returning (read_fd, write_fd) as raw fd numbers.
+fn create_pipe() -> io::Result<(u32, u32)> {
+    let mut read_fd: u32 = 0;
+    let mut write_fd: u32 = 0;
+    let errno = unsafe { fd_pipe(&mut read_fd, &mut write_fd) };
+    if errno != 0 {
+        return Err(wasi_err(errno));
+    }
+    // Match native Rust's anonymous-pipe invariant: std-owned child-process
+    // pipe ends are close-on-exec until an explicit spawn dup2 installs the
+    // selected endpoint at stdin/stdout/stderr. The OwnedFd guards ensure a
+    // partial fcntl failure cannot leak either descriptor.
+    let read_guard = unsafe { OwnedFd::from_raw_fd(read_fd as RawFd) };
+    let write_guard = unsafe { OwnedFd::from_raw_fd(write_fd as RawFd) };
+    for fd in [read_fd, write_fd] {
+        let errno = unsafe { fd_setfd(fd, 1) };
+        if errno != 0 {
+            return Err(wasi_err(errno));
+        }
+    }
+    Ok((
+        read_guard.into_raw_fd() as u32,
+        write_guard.into_raw_fd() as u32,
+    ))
+}
+
+/// Wrap a raw fd number into a ChildPipe.
+fn child_pipe_from_raw(raw: u32) -> ChildPipe {
+    ChildPipe(FileDesc::from_inner(unsafe { OwnedFd::from_raw_fd(raw as RawFd) }))
+}
