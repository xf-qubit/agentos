+// ============================================================
+// Command
+// ============================================================
+
+pub struct Command {
+    program: OsString,
+    args: Vec<OsString>,
+    env: CommandEnv,
+    cwd: Option<OsString>,
+    stdin: Option<Stdio>,
+    stdout: Option<Stdio>,
+    stderr: Option<Stdio>,
+}
+
+impl Command {
+    pub fn new(program: &OsStr) -> Command {
+        Command {
+            program: program.to_owned(),
+            args: vec![program.to_owned()],
+            env: Default::default(),
+            cwd: None,
+            stdin: None,
+            stdout: None,
+            stderr: None,
+        }
+    }
+
+    pub fn arg(&mut self, arg: &OsStr) {
+        self.args.push(arg.to_owned());
+    }
+
+    pub fn env_mut(&mut self) -> &mut CommandEnv {
+        &mut self.env
+    }
+
+    pub fn cwd(&mut self, dir: &OsStr) {
+        self.cwd = Some(dir.to_owned());
+    }
+
+    pub fn stdin(&mut self, stdin: Stdio) {
+        self.stdin = Some(stdin);
+    }
+
+    pub fn stdout(&mut self, stdout: Stdio) {
+        self.stdout = Some(stdout);
+    }
+
+    pub fn stderr(&mut self, stderr: Stdio) {
+        self.stderr = Some(stderr);
+    }
+
+    pub fn get_program(&self) -> &OsStr {
+        &self.program
+    }
+
+    pub fn get_args(&self) -> CommandArgs<'_> {
+        let mut iter = self.args.iter();
+        iter.next();
+        CommandArgs { iter }
+    }
+
+    pub fn get_envs(&self) -> CommandEnvs<'_> {
+        self.env.iter()
+    }
+
+    pub fn get_env_clear(&self) -> bool {
+        self.env.does_clear()
+    }
+
+    pub fn get_current_dir(&self) -> Option<&Path> {
+        self.cwd.as_ref().map(|cs| Path::new(cs))
+    }
+
+    /// Serialize args as null-separated byte buffer.
+    fn serialize_argv(&self) -> Vec<u8> {
+        let mut buf = Vec::new();
+        for arg in &self.args {
+            buf.extend_from_slice(arg.as_bytes());
+            buf.push(0);
+        }
+        buf
+    }
+
+    /// Serialize environment as KEY=VALUE\0 byte buffer.
+    fn serialize_envp(&self) -> Vec<u8> {
+        let mut buf = Vec::new();
+        // Capture applies clear, override, and removal semantics before
+        // serialization. In particular, env_remove must not leave the inherited
+        // value earlier in this NUL-separated buffer.
+        for (key, value) in self.env.capture() {
+            buf.extend_from_slice(key.as_bytes());
+            buf.push(b'=');
+            buf.extend_from_slice(value.as_bytes());
+            buf.push(0);
+        }
+        buf
+    }
+
+    /// Resolve a Stdio option into (child_fd, optional_parent_pipe).
+    /// If `use_pipe_default` is true and `stdio` is None, creates a pipe.
+    fn setup_one_stdio(
+        stdio: &Option<Stdio>,
+        default_fd: u32,
+        is_input: bool,
+        use_pipe_default: bool,
+    ) -> io::Result<(u32, Option<ChildPipe>, Option<OwnedFd>)> {
+        let make_pipe = || -> io::Result<(u32, Option<ChildPipe>, Option<OwnedFd>)> {
+            let (read_fd, write_fd) = create_pipe()?;
+            if is_input {
+                Ok((read_fd, Some(child_pipe_from_raw(write_fd)),
+                    Some(unsafe { OwnedFd::from_raw_fd(read_fd as RawFd) })))
+            } else {
+                Ok((write_fd, Some(child_pipe_from_raw(read_fd)),
+                    Some(unsafe { OwnedFd::from_raw_fd(write_fd as RawFd) })))
+            }
+        };
+
+        match stdio {
+            None if use_pipe_default => make_pipe(),
+            None | Some(Stdio::Inherit) => Ok((default_fd, None, None)),
+            Some(Stdio::Null) => {
+                Ok((u32::MAX, None, None))
+            }
+            Some(Stdio::MakePipe) => make_pipe(),
+            Some(Stdio::ParentStdout) => Ok((1, None, None)),
+            Some(Stdio::ParentStderr) => Ok((2, None, None)),
+            Some(Stdio::InheritFile(file)) => {
+                Ok((file.as_raw_fd() as u32, None, None))
+            }
+        }
+    }
+
+    pub fn spawn(
+        &mut self,
+        default: Stdio,
+        _needs_stdin: bool,
+    ) -> io::Result<(Process, StdioPipes)> {
+        let argv = self.serialize_argv();
+        let envp = self.serialize_envp();
+
+        // Get working directory bytes
+        let cwd_bytes = match &self.cwd {
+            Some(dir) => dir.as_bytes().to_vec(),
+            None => {
+                let cwd = crate::env::current_dir()?;
+                cwd.as_os_str().as_bytes().to_vec()
+            }
+        };
+
+        let use_pipes = matches!(default, Stdio::MakePipe);
+
+        let (child_stdin_fd, parent_stdin, child_stdin_guard) =
+            Self::setup_one_stdio(&self.stdin, 0, true, use_pipes)?;
+        let (child_stdout_fd, parent_stdout, child_stdout_guard) =
+            Self::setup_one_stdio(&self.stdout, 1, false, use_pipes)?;
+        let (child_stderr_fd, parent_stderr, child_stderr_guard) =
+            Self::setup_one_stdio(&self.stderr, 2, false, use_pipes)?;
+
+        let mut actions = Vec::new();
+        for (source, target) in [
+            (child_stdin_fd, 0),
+            (child_stdout_fd, 1),
+            (child_stderr_fd, 2),
+        ] {
+            if source != target {
+                append_stdio_action(&mut actions, source, target);
+            }
+        }
+        // Close both unused halves only after every dup, so an fd needed by a
+        // later stdio action cannot be invalidated by an earlier pipe cleanup.
+        let mut closed = [u32::MAX; 6];
+        let mut closed_len = 0;
+        for raw_fd in [
+            child_stdin_guard.as_ref().map(|fd| fd.as_raw_fd()),
+            child_stdout_guard.as_ref().map(|fd| fd.as_raw_fd()),
+            child_stderr_guard.as_ref().map(|fd| fd.as_raw_fd()),
+            parent_stdin.as_ref().map(|pipe| pipe.0.as_raw_fd()),
+            parent_stdout.as_ref().map(|pipe| pipe.0.as_raw_fd()),
+            parent_stderr.as_ref().map(|pipe| pipe.0.as_raw_fd()),
+        ].into_iter().flatten().map(|fd| fd as u32) {
+            if raw_fd > 2 && !closed[..closed_len].contains(&raw_fd) {
+                append_spawn_action(&mut actions, FDOP_CLOSE, raw_fd, 0, 0, &[]);
+                closed[closed_len] = raw_fd;
+                closed_len += 1;
+            }
+        }
+
+        // Query the authoritative mask so ordinary Command spawning inherits it.
+        let mut sigmask_lo = 0;
+        let mut sigmask_hi = 0;
+        let mask_errno = unsafe {
+            proc_signal_mask_v2(3, 0, 0, &mut sigmask_lo, &mut sigmask_hi)
+        };
+        if mask_errno != 0 {
+            return Err(wasi_err(mask_errno));
+        }
+
+        // Spawn the child process. The pipe guards keep child ends alive through
+        // the call and close them in the parent before this function returns.
+        let mut pid: u32 = 0;
+        let errno = unsafe {
+            proc_spawn_v3(
+                self.program.as_bytes().as_ptr(),
+                self.program.as_bytes().len() as u32,
+                argv.as_ptr(),
+                argv.len() as u32,
+                envp.as_ptr(),
+                envp.len() as u32,
+                actions.as_ptr(),
+                actions.len() as u32,
+                cwd_bytes.as_ptr(),
+                cwd_bytes.len() as u32,
+                0,
+                0,
+                0,
+                sigmask_lo,
+                sigmask_hi,
+                0,
+                &mut pid,
+            )
+        };
+
+        if errno != 0 {
+            return Err(wasi_err(errno));
+        }
+
+        let pipes = StdioPipes {
+            stdin: parent_stdin,
+            stdout: parent_stdout,
+            stderr: parent_stderr,
+        };
+
+        Ok((Process { pid, status: None }, pipes))
+    }
+}
+
+impl fmt::Debug for Command {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        if f.alternate() {
+            let mut debug_command = f.debug_struct("Command");
+            debug_command.field("program", &self.program).field("args", &self.args);
+            if !self.env.is_unchanged() {
+                debug_command.field("env", &self.env);
+            }
+            if self.cwd.is_some() {
+                debug_command.field("cwd", &self.cwd);
+            }
+            if self.stdin.is_some() {
+                debug_command.field("stdin", &self.stdin);
+            }
+            if self.stdout.is_some() {
+                debug_command.field("stdout", &self.stdout);
+            }
+            if self.stderr.is_some() {
+                debug_command.field("stderr", &self.stderr);
+            }
+            debug_command.finish()
+        } else {
+            if let Some(ref cwd) = self.cwd {
+                write!(f, "cd {cwd:?} && ")?;
+            }
+            if self.env.does_clear() {
+                write!(f, "env -i ")?;
+            } else {
+                let mut any_removed = false;
+                for (key, value_opt) in self.get_envs() {
+                    if value_opt.is_none() {
+                        if !any_removed {
+                            write!(f, "env ")?;
+                            any_removed = true;
+                        }
+                        write!(f, "-u {} ", key.to_string_lossy())?;
+                    }
+                }
+            }
+            for (key, value_opt) in self.get_envs() {
+                if let Some(value) = value_opt {
+                    write!(f, "{}={value:?} ", key.to_string_lossy())?;
+                }
+            }
+            if self.program != self.args[0] {
+                write!(f, "[{:?}] ", self.program)?;
+            }
+            write!(f, "{:?}", self.args[0])?;
+            for arg in &self.args[1..] {
+                write!(f, " {:?}", arg)?;
+            }
+            Ok(())
+        }
+    }
+}
