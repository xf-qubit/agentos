  limitName: optional<str>
  configuredLimit: optional<u64>
  currentUsage: optional<u64>
  requested: optional<u64>
  unit: optional<str>
  scope: optional<str>
  vmId: optional<str>
  sessionGeneration: optional<u64>
  capabilityId: optional<u64>
  operation: optional<str>
  configurationPath: optional<str>
  retryable: optional<bool>
