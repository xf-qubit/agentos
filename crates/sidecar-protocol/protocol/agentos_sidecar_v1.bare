}

type PtyResizedResponse struct {
  processId: str
  cols: u16
  rows: u16
}

type StdinClosedResponse struct {
  processId: str
}

type ProcessKilledResponse struct {
  processId: str
}

type ProcessSnapshotStatus enum {
  RUNNING
  EXITED
  STOPPED
}

type ProcessSnapshotEntry struct {
  processId: str
  pid: u32
  ppid: u32
  pgid: u32
  sid: u32
  driver: str
  command: str
