  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "docs:gen:ts": "typedoc",
    "check-types": "astro check",
    "build": "pnpm run docs:gen:ts && astro build",
    "preview": "astro preview",
