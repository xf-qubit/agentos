---
// Deploy target cards for the docs. The target list is shared with the
// registry page's Deploy section via src/data/deploy-targets.ts.
import { DEPLOY_TARGETS } from "../data/deploy-targets";
---

<div class="deploy-targets">
	{
		DEPLOY_TARGETS.map((target) => (
			<a class="deploy-target" href={target.href}>
				<span class="deploy-target__label">
					<img class="deploy-target__icon" src={target.image} alt="" />
					<span class="deploy-target__title">{target.title}</span>
				</span>
				<svg
					class="deploy-target__arrow"
					viewBox="0 0 448 512"
					fill="currentColor"
					aria-hidden="true"
				>
					<path d="M438.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L338.8 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l306.7 0L233.4 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z" />
				</svg>
			</a>
		))
	}
</div>

<style>
	.deploy-targets {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		margin: 1.5rem 0;
	}

	@media (min-width: 768px) {
		.deploy-targets {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.deploy-target {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		/* Matches Rivet's docs Card: px-8 (32px) + mt-6/pb-6 (24px). */
		padding: 24px 32px;
		border: 1px solid rgba(27, 25, 22, 0.15);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.55);
		color: inherit;
		text-decoration: none;
		transition: border-color 0.2s ease;
	}

	.deploy-target:hover {
		border-color: rgba(27, 25, 22, 0.3);
	}

	.deploy-target__label {
		display: flex;
		align-items: center;
		gap: 12px;
		min-width: 0;
		margin: 0;
	}

	.deploy-target__icon {
		height: 16px;
		width: auto;
		max-width: 40px;
		flex-shrink: 0;
		/* Reset the prose img margin that otherwise inflates the row. */
		margin: 0;
	}

	.deploy-target__title {
		font-weight: 500;
		color: #1b1916;
		line-height: 24px;
		margin: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.deploy-target__arrow {
		height: 14px;
		width: auto;
		flex-shrink: 0;
		color: #8a8478;
		margin: 0;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.deploy-target:hover .deploy-target__arrow {
		color: #1b1916;
		transform: translateX(3px);
	}
</style>
