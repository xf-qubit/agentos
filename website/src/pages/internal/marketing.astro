---
// Internal, unlinked, temporary v0.2 announcement card (mosaic bento layout).
// Not in any nav and explicitly noindex — meant to be screenshotted / screen-
// recorded as a ~2:1 social asset. The card + reveal animation live in the
// MosaicAnnouncement island so the logo plays its intro once and then docks
// into the bento.
import "../../styles/global.css";
import MosaicAnnouncement from "../../components/marketing/MosaicAnnouncement";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<title>Introducing v0.2 — agentOS</title>
	</head>
	<body class="paper-grain flex min-h-screen items-center justify-center bg-cream p-8 font-sans text-ink">
		<MosaicAnnouncement client:load />

		<style is:global>
			.logo-anim svg {
				height: 100% !important;
				width: auto;
			}
		</style>
	</body>
</html>
