---
import Layout from "../../layouts/Layout.astro";
import { Navigation } from "../../components/Navigation";
import { Footer } from "../../components/Footer";
import { registry } from "../../data/registry";
import { REGISTRY_ICONS } from "../../data/registry-icons";
import { InkChip, InkPanel } from "../../components/marketing/editorial/InkPanel";
// Use the docs theme's Shiki highlighter so registry code matches the docs
// code blocks exactly (ayu-dark), instead of the old custom light palette.
import { highlightCode as highlightCodeHtml } from "@rivet-dev/docs-theme/lib/highlight";

export function getStaticPaths() {
	// External entries (deploy targets) link out from the index card and have
	// no detail page.
	return registry
		.filter((entry) => entry.status !== "external")
		.map((entry) => ({
			params: { slug: entry.slug },
			props: { entry },
		}));
}

const { entry } = Astro.props;

const TYPE_LABELS: Record<string, string> = {
	"file-system": "File System",
	tool: "Bindings",
	agent: "Agent",
	"sandbox-extension": "Sandbox Mounting",
	software: "Software",
	browser: "Browser",
};

// Turn a package's last path segment into a JS identifier, e.g.
// `@agentos-software/build-essential` -> `buildEssential`.
const toIdent = (s: string) =>
	s.replace(/^.*\//, "").replace(/-([a-z0-9])/g, (_, c) => c.toUpperCase());

const isComingSoon = entry.status === "coming-soon";
const isConfig = entry.status === "config";
const isDocs = entry.status === "docs";
// Browser packages are installable software too — same registration example.
const isSoftware =
	entry.status === "available" &&
	(entry.types.includes("software") || entry.types.includes("browser"));
const isSandboxExt =
	entry.status === "available" && entry.types.includes("sandbox-extension");
const isTool =
	entry.status === "available" &&
	!isSoftware &&
	!isSandboxExt &&
	entry.types.includes("tool");
const isAvailableAgent =
	entry.status === "available" &&
	entry.types.includes("agent") &&
	!!entry.agentId;

const npmHref =
	entry.status === "available"
		? `https://www.npmjs.com/package/${entry.package}`
		: null;

// Docs link: an entry's own docsHref (always set for agents) wins; config
// entries, built-in docs entries, software, and sandbox mounting providers
// fall back to the relevant documentation page for their type.
const docsHref =
	entry.docsHref ??
	(isSoftware ? "/docs/software" : isSandboxExt ? "/docs/sandbox" : null);

const configId = entry.status === "config" ? entry.configId : null;
const agentId = entry.status === "docs" ? (entry.agentId ?? null) : null;

// The code example shown on the page. Config entries carry their own; software
// and sandbox-mounting entries get an auto-generated registration example.
let exampleSource: string | null = null;
if (entry.status === "config") {
	exampleSource = entry.configExample;
} else if (isSoftware && entry.status === "available") {
	const ident = toIdent(entry.package);
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import ${ident} from "${entry.package}";

// Add the package to your VM's software so its commands are available inside the VM
const vm = agentOS({ software: [${ident}] });

export const registry = setup({ use: { vm } });`;
} else if (isSandboxExt) {
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import { createSandboxFs, createSandboxToolkit } from "@rivet-dev/agentos-sandbox";
import { SandboxAgent } from "sandbox-agent";
import { ${entry.slug} } from "sandbox-agent/${entry.slug}";

// Start a ${entry.title}-backed sandbox and mount it into the VM
const sandbox = await SandboxAgent.start({ sandbox: ${entry.slug}() });

const vm = agentOS({
  mounts: [{ path: "/home/agentos/sandbox", plugin: createSandboxFs({ client: sandbox }) }],
  toolKits: [createSandboxToolkit({ client: sandbox })],
});

export const registry = setup({ use: { vm } });`;
} else if (isTool) {
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import { createSandboxFs, createSandboxToolkit } from "@rivet-dev/agentos-sandbox";
import { SandboxAgent } from "sandbox-agent";
import { docker } from "sandbox-agent/docker";

// Mount the sandbox filesystem and expose its process tools to the VM
const sandbox = await SandboxAgent.start({ sandbox: docker() });

const vm = agentOS({
  mounts: [{ path: "/home/agentos/sandbox", plugin: createSandboxFs({ client: sandbox }) }],
  toolKits: [createSandboxToolkit({ client: sandbox })],
});

export const registry = setup({ use: { vm } });`;
} else if (isAvailableAgent) {
	// An installable agent adapter (e.g. pi): npm package + session agent id.
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import ${entry.agentId} from "${entry.package}";

// Register the ${entry.title} adapter as VM software
const vm = agentOS({ software: [${entry.agentId}] });

export const registry = setup({ use: { vm } });

// Then start a session from your client with the "${entry.agentId}" agent id:
// const session = await agent.createSession("${entry.agentId}", { env: { /* API keys */ } });`;
} else if (isDocs && entry.status === "docs" && entry.package && entry.agentId) {
	// Built-in agent adapter: register it as VM software, then open a session
	// with its agent id. The import identifier matches the agent id (e.g.
	// `import claude from "@agentos-software/claude-code"`).
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import ${entry.agentId} from "${entry.package}";

// Register the ${entry.title} adapter as VM software
const vm = agentOS({ software: [${entry.agentId}] });

export const registry = setup({ use: { vm } });

// Then start a session from your client with the "${entry.agentId}" agent id:
// const session = await agent.createSession("${entry.agentId}", { env: { /* API keys */ } });`;
}
const exampleHtml = exampleSource
	? await highlightCodeHtml(exampleSource, "ts")
	: null;

// Plain npm install is only shown for entries that aren't software or
// sandbox-mounting (those show a registration example instead).
const installCmd =
	entry.status === "available" && !isSoftware && !isSandboxExt
		? `npm install ${entry.package}`
		: null;

const EntryIcon = entry.icon ? REGISTRY_ICONS[entry.icon] : undefined;
---

<Layout
	title={entry.title}
	description={entry.description}
>
	<Navigation client:load />
	<main class="paper-grain min-h-screen w-full overflow-x-hidden font-sans text-ink-soft">
		<div class="relative isolate overflow-hidden pt-40">
			<div class="mx-auto max-w-3xl px-6 lg:px-8">
				<a
					href="/registry"
					class="mb-8 inline-flex items-center text-sm text-ink-faint no-underline transition-colors hover:text-ink"
				>
					&larr; Back to Registry
				</a>

				<div class="mb-4 flex items-center gap-4">
					{entry.image && (
						<img
							src={entry.image}
							alt={entry.title}
							width={40}
							height={40}
							class="object-contain"
						/>
					)}
					{EntryIcon && (
						<EntryIcon className="h-10 w-10 text-olive" />
					)}
					<h1 class="text-4xl font-medium leading-[1.06] tracking-[-0.015em] text-ink md:text-5xl">
						{entry.title}
					</h1>
					{isComingSoon && (
						<span class="rounded-full border border-ink/15 px-2.5 py-1 text-xs text-ink-faint">
							Coming Soon
						</span>
					)}
					{entry.beta && (
						<span class="rounded-full border border-ink/15 px-2.5 py-1 text-xs text-ink-faint">
							Beta
						</span>
					)}
				</div>

				<div class="mt-4 flex gap-2">
					{entry.types.map((type: string) => (
						<span
							class="rounded-full border border-pine/30 bg-pine/5 px-2 py-0.5 font-mono text-[11px] uppercase tracking-[0.12em] text-pine"
						>
							{TYPE_LABELS[type]}
						</span>
					))}
				</div>

				<p class="mt-6 text-lg leading-relaxed text-ink-soft">
					{entry.description}
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-3xl px-6 pt-10 pb-24 lg:px-8">
			{isComingSoon ? (
				<div class="border border-ink/10 bg-white/55 p-8 text-center">
					<p class="text-lg text-ink-faint">This integration is coming soon.</p>
				</div>
			) : isDocs ? (
				<>
					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">{exampleHtml ? "Add to agentOS" : "Documentation"}</h2>
						<p class="mb-4 text-sm text-ink-soft">
							{exampleHtml && agentId ? (
								<>
									Register the {entry.title} adapter as your VM's{" "}
									<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">software: []</code>, then open a session with the{" "}
									<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">{agentId}</code>{" "}
									agent id.
								</>
							) : (
								"Built into agentOS — no separate install. See the docs for setup and usage."
							)}
						</p>
						{exampleHtml && (
							<InkPanel className="mb-6">
								<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
							</InkPanel>
						)}
					</section>

					<a
						href={docsHref!}
						class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
					>
						View documentation
					</a>
				</>
			) : isConfig ? (
				<>
					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">Configuration</h2>
						<p class="mb-4 text-sm text-ink-soft">
							Built into the SDK — no separate install. Enable it with{" "}
							<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">{configId}</code>{" "}
							in your VM config.
						</p>
						<InkPanel className="mb-6">
							<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
						</InkPanel>
					</section>

					<a
						href={docsHref!}
						class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
					>
						View documentation
					</a>
				</>
			) : isSoftware ? (
				<>
					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
						<InkChip command={`npm install ${entry.package}`} className="mb-8" />
					</section>

					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">2. Add to agentOS</h2>
						<p class="mb-4 text-sm text-ink-soft">
							Register it with your VM's{" "}
							<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">software: []</code>{" "}
							so its commands are available inside the VM.
						</p>
						<InkPanel className="mb-6">
							<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
						</InkPanel>
					</section>

					<div class="flex flex-wrap gap-3">
						<a
							href={docsHref!}
							class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
						>
							View documentation
						</a>
						<a
							href={npmHref!}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
						>
							View on npm
						</a>
					</div>
				</>
			) : isSandboxExt || isTool ? (
				<>
					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
						<InkChip
							command="npm install @rivet-dev/agentos-sandbox sandbox-agent"
							className="mb-8"
						/>
					</section>

					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">2. Add to agentOS</h2>
						<p class="mb-4 text-sm text-ink-soft">
							{isSandboxExt ? (
								<>
									Mount a {entry.title} sandbox into the VM with{" "}
									<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">@rivet-dev/agentos-sandbox</code>.
								</>
							) : (
								<>
									Mount the sandbox filesystem and register the process
									bindings with{" "}
									<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">@rivet-dev/agentos-sandbox</code>.
								</>
							)}
						</p>
						<InkPanel className="mb-6">
							<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
						</InkPanel>
					</section>

					<div class="flex flex-wrap gap-3">
						<a
							href={docsHref!}
							class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
						>
							View documentation
						</a>
						<a
							href={npmHref!}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
						>
							View on npm
						</a>
					</div>
				</>
			) : isAvailableAgent ? (
				<>
					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
						<InkChip command={`npm install ${entry.package}`} className="mb-8" />
					</section>

					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">2. Add to agentOS</h2>
						<p class="mb-4 text-sm text-ink-soft">
							Register the {entry.title} adapter as your VM's{" "}
							<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">software: []</code>, then open a session with the{" "}
							<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">{entry.agentId}</code>{" "}
							agent id.
						</p>
						<InkPanel className="mb-6">
							<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
						</InkPanel>
					</section>

					<div class="flex flex-wrap gap-3">
						<a
							href={docsHref!}
							class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
						>
							View documentation
						</a>
						<a
							href={npmHref!}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
						>
							View on npm
						</a>
					</div>
				</>
			) : (
				<>
					<section>
						<h2 class="mb-3 text-xl font-medium text-ink">Install</h2>
						<InkChip command={installCmd!} className="mb-6" />
					</section>

					<a
						href={npmHref!}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center rounded-lg border border-ink/20 px-4 py-2 text-sm font-medium text-ink-soft no-underline transition-colors hover:border-ink/40 hover:text-ink"
					>
						View on npm
					</a>
				</>
			)}
		</div>
	</main>
	<Footer client:visible />
</Layout>
