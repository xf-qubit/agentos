---
import Layout from "../../layouts/Layout.astro";
import { Navigation } from "../../components/Navigation";
import { Footer } from "../../components/Footer";
import { registry } from "../../data/registry";
import { InkPanel } from "../../components/marketing/editorial/InkPanel";
import { RegistryIconTile } from "../../components/marketing/registry/RegistryIconTile";
import InstallRow from "../../components/marketing/registry/InstallRow.astro";
// Use the docs theme's Shiki highlighter so registry code matches the docs
// code blocks exactly (ayu-dark), instead of the old custom light palette.
import { highlightCode as highlightCodeHtml } from "@rivet-dev/docs-theme/lib/highlight";

export function getStaticPaths() {
	// External entries (deploy targets) link out from the index card and have
	// no detail page.
	return registry
		.filter((entry) => entry.status !== "external")
		.map((entry) => ({
			params: { slug: entry.slug },
			props: { entry },
		}));
}

const { entry } = Astro.props;

const TYPE_LABELS: Record<string, string> = {
	"file-system": "File System",
	binding: "Bindings",
	agent: "Agent",
	"sandbox-extension": "Sandbox Mounting",
	software: "Software",
	browser: "Browser",
};

// Turn a package's last path segment into a JS identifier, e.g.
// `@agentos-software/build-essential` -> `buildEssential`.
const toIdent = (s: string) =>
	s.replace(/^.*\//, "").replace(/-([a-z0-9])/g, (_, c) => c.toUpperCase());

const isComingSoon = entry.status === "coming-soon";
const isConfig = entry.status === "config";
const isDocs = entry.status === "docs";
// Browser packages are installable software too — same registration example.
const isSoftware =
	entry.status === "available" &&
	(entry.types.includes("software") || entry.types.includes("browser"));
const isSandboxExt =
	entry.status === "available" && entry.types.includes("sandbox-extension");
const isBinding =
	entry.status === "available" &&
	!isSoftware &&
	!isSandboxExt &&
	entry.types.includes("binding");
const isAvailableAgent =
	entry.status === "available" &&
	entry.types.includes("agent") &&
	!!entry.agentId;

// Any entry can carry a package (docs entries for built-in agent adapters do
// too); the ribbon and Information section link it to npm.
const packageName = "package" in entry && entry.package ? entry.package : null;
const npmHref = packageName
	? `https://www.npmjs.com/package/${packageName}`
	: null;

// Docs link: an entry's own docsHref (always set for agents) wins; config
// entries, built-in docs entries, software, and sandbox mounting providers
// fall back to the relevant documentation page for their type.
const docsHref =
	entry.docsHref ??
	(isSoftware ? "/docs/software" : isSandboxExt ? "/docs/sandbox" : null);

const configId = entry.status === "config" ? entry.configId : null;
const agentId = entry.status === "docs" ? (entry.agentId ?? null) : null;

// The code example shown on the page. Config entries carry their own; software
// and sandbox-mounting entries get an auto-generated registration example.
let exampleSource: string | null = null;
if (entry.status === "config") {
	exampleSource = entry.configExample;
} else if (isSoftware && entry.status === "available") {
	const ident = toIdent(entry.package);
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import ${ident} from "${entry.package}";

// Add the package to your VM's software so its commands are available inside the VM
const vm = agentOS({ software: [${ident}] });

export const registry = setup({ use: { vm } });`;
} else if (isSandboxExt) {
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import { createSandboxFs, createSandboxBindings } from "@rivet-dev/agentos-sandbox";
import { SandboxAgent } from "sandbox-agent";
import { ${entry.slug} } from "sandbox-agent/${entry.slug}";

// Start a ${entry.title}-backed sandbox and mount it into the VM
const sandbox = await SandboxAgent.start({ sandbox: ${entry.slug}() });

const vm = agentOS({
  mounts: [{ path: "/home/agentos/sandbox", plugin: createSandboxFs({ client: sandbox }) }],
  bindings: [createSandboxBindings({ client: sandbox })],
});

export const registry = setup({ use: { vm } });`;
} else if (isBinding) {
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import { createSandboxFs, createSandboxBindings } from "@rivet-dev/agentos-sandbox";
import { SandboxAgent } from "sandbox-agent";
import { docker } from "sandbox-agent/docker";

// Mount the sandbox filesystem and expose its process bindings to the VM
const sandbox = await SandboxAgent.start({ sandbox: docker() });

const vm = agentOS({
  mounts: [{ path: "/home/agentos/sandbox", plugin: createSandboxFs({ client: sandbox }) }],
  bindings: [createSandboxBindings({ client: sandbox })],
});

export const registry = setup({ use: { vm } });`;
} else if (isAvailableAgent) {
	// An installable agent adapter (e.g. pi): npm package + session agent id.
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import ${entry.agentId} from "${entry.package}";

// Register the ${entry.title} adapter as VM software
const vm = agentOS({ software: [${entry.agentId}] });

export const registry = setup({ use: { vm } });

// Then start a session from your client with the "${entry.agentId}" agent id:
// await agent.openSession({ agent: "${entry.agentId}", env: { /* API keys */ } });`;
} else if (isDocs && entry.status === "docs" && entry.package && entry.agentId) {
	// Built-in agent adapter: register it as VM software, then open a session
	// with its agent id. The import identifier matches the agent id (e.g.
	// `import claude from "@agentos-software/claude-code"`).
	exampleSource = `import { agentOS, setup } from "@rivet-dev/agentos";
import ${entry.agentId} from "${entry.package}";

// Register the ${entry.title} adapter as VM software
const vm = agentOS({ software: [${entry.agentId}] });

export const registry = setup({ use: { vm } });

// Then start a session from your client with the "${entry.agentId}" agent id:
// await agent.openSession({ agent: "${entry.agentId}", env: { /* API keys */ } });`;
}
const exampleHtml = exampleSource
	? await highlightCodeHtml(exampleSource, "ts")
	: null;

// The install command shown in step 1; the inline Copy button copies it.
const installCommand =
	entry.status === "available"
		? isSandboxExt || isBinding
			? "npm install @rivet-dev/agentos-sandbox sandbox-agent"
			: `npm install ${entry.package}`
		: null;

const statusLabel = isComingSoon
	? "Coming Soon"
	: entry.beta
		? "Beta"
		: entry.status === "available"
			? "Available"
			: "Built in";

interface MetaCell {
	label: string;
	value: string;
	href?: string;
	external?: boolean;
	mono?: boolean;
}

// The cells of the horizontal metadata bar under the header, App Store
// Information-style. Keeps the header itself to icon + title + description.
const ribbon: MetaCell[] = [
	{
		label: "Category",
		value: entry.types.map((type) => TYPE_LABELS[type] ?? type).join(", "),
	},
	{ label: "Status", value: statusLabel },
	...(packageName && npmHref
		? [
				{
					label: "Package",
					value: packageName,
					href: npmHref,
					external: true,
					mono: true,
				},
			]
		: []),
	...(docsHref ? [{ label: "Docs", value: "Guide", href: docsHref }] : []),
];
---

<Layout
	title={entry.title}
	description={entry.description}
>
	<Navigation client:load />
	<main class="paper-grain min-h-screen w-full overflow-x-hidden font-sans text-ink-soft">
		<div class="relative isolate overflow-hidden pt-40">
			<div class="mx-auto max-w-4xl px-6 lg:px-8">
				<a
					href="/registry"
					class="mb-8 inline-flex items-center text-sm text-ink-faint no-underline transition-colors hover:text-ink"
				>
					&larr; Back to Registry
				</a>

				<div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:gap-8">
					<RegistryIconTile
						title={entry.title}
						image={entry.image}
						icon={entry.icon}
						size={96}
					/>
					<div class="min-w-0 flex-1">
						<h1 class="text-3xl font-medium leading-[1.06] tracking-[-0.015em] text-ink md:text-4xl">
							{entry.title}
						</h1>
						<p class="mt-3 max-w-2xl text-lg leading-relaxed text-ink-soft">
							{entry.description}
						</p>
					</div>
					{entry.status !== "available" && (
						<div class="shrink-0">
							{isComingSoon ? (
								<span
									aria-disabled="true"
									class="inline-flex items-center justify-center rounded-md border border-ink/15 px-6 py-2 text-sm font-medium text-ink-faint"
								>
									Coming soon
								</span>
							) : (
								<a
									href={docsHref!}
									class="selection-dark inline-flex items-center justify-center rounded-md bg-ink px-6 py-2 text-sm font-medium text-cream no-underline transition-colors hover:bg-ink/85"
								>
									View docs
								</a>
							)}
						</div>
					)}
				</div>

				<div class="mt-10 flex divide-x divide-ink/10 overflow-x-auto border-y border-ink/10">
					{ribbon.map((cell) => (
						<div class="min-w-[7.5rem] flex-1 px-4 py-4 text-center">
							<div class="text-[13px] text-ink-faint">{cell.label}</div>
							{cell.href ? (
								<a
									href={cell.href}
									{...(cell.external
										? { target: "_blank", rel: "noopener noreferrer" }
										: {})}
									class={`mt-1 block truncate text-sm font-medium text-ink no-underline hover:underline ${cell.mono ? "font-mono text-[13px]" : ""}`}
									title={cell.value}
								>
									{cell.value}
								</a>
							) : (
								<div
									class="mt-1 truncate text-sm font-medium text-ink"
									title={cell.value}
								>
									{cell.value}
								</div>
							)}
						</div>
					))}
				</div>
			</div>
		</div>

		<div class="mx-auto max-w-4xl px-6 pb-24 lg:px-8">
			{isComingSoon ? (
				<div class="mt-12 rounded-2xl border border-dashed border-ink/15 bg-white/40 p-10 text-center">
					<p class="text-lg text-ink-faint">This integration is coming soon.</p>
					<a
						href="https://github.com/rivet-dev/agentos/issues"
						target="_blank"
						rel="noopener noreferrer"
						class="mt-3 inline-block text-sm font-medium text-pine no-underline hover:underline"
					>
						Request an Extension
					</a>
				</div>
			) : (
				<section id="get-started" class="mt-12">
					{isDocs ? (
						<>
							<h2 class="mb-3 text-xl font-medium text-ink">
								{exampleHtml ? "Add to agentOS" : "Documentation"}
							</h2>
							<p class="mb-4 text-sm text-ink-soft">
								{exampleHtml && agentId ? (
									<>
										Register the {entry.title} adapter as your VM's{" "}
										<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">software: []</code>, then open a session with the{" "}
										<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">{agentId}</code>{" "}
										agent id.
									</>
								) : (
									"Built into agentOS — no separate install. See the docs for setup and usage."
								)}
							</p>
							{exampleHtml && (
								<InkPanel className="mb-6">
									<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
								</InkPanel>
							)}
						</>
					) : isConfig ? (
						<>
							<h2 class="mb-3 text-xl font-medium text-ink">Configuration</h2>
							<p class="mb-4 text-sm text-ink-soft">
								Built into the SDK — no separate install. Enable it with{" "}
								<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">{configId}</code>{" "}
								in your VM config.
							</p>
							<InkPanel className="mb-6">
								<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
							</InkPanel>
						</>
					) : isSoftware ? (
						<>
							<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
							<InstallRow command={installCommand!} class="mb-8" />

							<h2 class="mb-3 text-xl font-medium text-ink">2. Add to agentOS</h2>
							<p class="mb-4 text-sm text-ink-soft">
								Register it with your VM's{" "}
								<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">software: []</code>{" "}
								so its commands are available inside the VM.
							</p>
							<InkPanel className="mb-6">
								<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
							</InkPanel>
						</>
					) : isSandboxExt || isBinding ? (
						<>
							<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
							<InstallRow command={installCommand!} class="mb-8" />

							<h2 class="mb-3 text-xl font-medium text-ink">2. Add to agentOS</h2>
							<p class="mb-4 text-sm text-ink-soft">
								{isSandboxExt ? (
									<>
										Mount a {entry.title} sandbox into the VM with{" "}
										<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">@rivet-dev/agentos-sandbox</code>.
									</>
								) : (
									<>
										Mount the sandbox filesystem and register the process
										bindings with{" "}
										<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">@rivet-dev/agentos-sandbox</code>.
									</>
								)}
							</p>
							<InkPanel className="mb-6">
								<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
							</InkPanel>
						</>
					) : isAvailableAgent ? (
						<>
							<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
							<InstallRow command={installCommand!} class="mb-8" />

							<h2 class="mb-3 text-xl font-medium text-ink">2. Add to agentOS</h2>
							<p class="mb-4 text-sm text-ink-soft">
								Register the {entry.title} adapter as your VM's{" "}
								<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">software: []</code>, then open a session with the{" "}
								<code class="rounded bg-ink/5 px-1.5 py-0.5 font-mono text-[13px] text-ink">{entry.agentId}</code>{" "}
								agent id.
							</p>
							<InkPanel className="mb-6">
								<div class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed" set:html={exampleHtml} />
							</InkPanel>
						</>
					) : (
						<>
							<h2 class="mb-3 text-xl font-medium text-ink">1. Install</h2>
							<InstallRow command={installCommand!} class="mb-6" />
						</>
					)}
				</section>
			)}
		</div>
	</main>
	<Footer client:visible />
</Layout>

<script>
	// "Copy" buttons next to install commands: copy the command, then briefly
	// swap the label to "Copied" and show the check icon so the action is
	// visible. Toggling the label span (not the button's textContent) keeps the
	// icons intact.
	for (const button of document.querySelectorAll<HTMLButtonElement>(
		"button[data-copy-command]",
	)) {
		const label = button.querySelector<HTMLElement>("[data-copy-label]");
		const copyIcon = button.querySelector<SVGElement>('[data-copy-icon="copy"]');
		const checkIcon = button.querySelector<SVGElement>('[data-copy-icon="check"]');
		let timer: number | undefined;
		button.addEventListener("click", async () => {
			try {
				await navigator.clipboard.writeText(button.dataset.copyCommand ?? "");
				if (label) label.textContent = "Copied";
				copyIcon?.classList.add("hidden");
				checkIcon?.classList.remove("hidden");
				window.clearTimeout(timer);
				timer = window.setTimeout(() => {
					if (label) label.textContent = "Copy";
					checkIcon?.classList.add("hidden");
					copyIcon?.classList.remove("hidden");
				}, 1500);
			} catch (error) {
				console.error("copying the install command failed", error);
			}
		});
	}
</script>
