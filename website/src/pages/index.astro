---
import Layout from "../layouts/Layout.astro";
import { Navigation } from "../components/Navigation";
import { Footer } from "../components/Footer";
import AgentOSPage from "../components/marketing/solutions/AgentOSPage";
import { highlightCodeHtml } from "../lib/highlight-code";

const heroTabSnippets = [
	{ key: 'agents', fileName: 'agents.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent").connect();

// Stream events (tool calls, text output, etc.)
agent.on("sessionEvent", (data) => console.log(data.event));

// Create a session and send a prompt
const session = await agent.createSession("pi", { env: { ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY! } });
await agent.sendPrompt(session.sessionId, "Write a Python script that calculates pi");` },

	{ key: 'tools', fileName: 'tools.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";
import common from "@agentos-software/common";
import { z } from "zod";

// A bindings group becomes CLI commands inside the VM:
// $ agentos-weather get --city London
const weather = {
  name: "weather",
  description: "Look up weather information for cities.",
  bindings: {
    get: {
      description: "Get the current weather for a city.",
      inputSchema: z.object({ city: z.string().describe("City name (e.g. 'London').") }),
      execute: async ({ city }: { city: string }) => ({
        city,
        temperature: 18,
        conditions: "partly cloudy",
      }),
    },
  },
};

const vm = agentOS({ software: [common], bindings: [weather] });
export const registry = setup({ use: { vm } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

// Bindings are injected into the agent's system prompt automatically
const session = await agent.createSession("pi");
await agent.sendPrompt(session.sessionId, "What's the weather in London?");
// The agent will call: agentos-weather get --city London` },

	{ key: 'agent-agent', fileName: 'agent-agent.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";
import { createClient } from "@rivet-dev/agentos/client";
import { z } from "zod";

// The reviewer is its own isolated agent VM
const reviewer = agentOS({});

// Bridge: copy a file from the writer's VM to the reviewer's, then review it
async function reviewFile(path: string) {
  const client = createClient<typeof registry>("http://localhost:6420");
  const writer = client.writer.getOrCreate("my-project");
  const reviewerHandle = client.reviewer.getOrCreate("my-project");

  const code = await writer.readFile(path);
  await reviewerHandle.writeFile(path, code);

  const session = await reviewerHandle.createSession("pi");
  const { text } = await reviewerHandle.sendPrompt(session.sessionId, \`Review \${path}\`);
  return text;
}

// The writer gets a "review" binding -> agentos-review submit --path ...
const writer = agentOS({
  bindings: [{
    name: "review",
    description: "Send code to the reviewer agent",
    bindings: {
      submit: {
        description: "Submit a file for code review",
        inputSchema: z.object({ path: z.string().describe("Path to the file") }),
        execute: async ({ path }: { path: string }) => ({ review: await reviewFile(path) }),
      },
    },
  }],
});

export const registry = setup({ use: { writer, reviewer } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const writer = client.writer.getOrCreate("my-project");

const session = await writer.createSession("pi");
await writer.sendPrompt(
  session.sessionId,
  "Write a REST API at /home/agentos/api.ts, then run agentos-review submit --path /home/agentos/api.ts",
);` },

	{ key: 'nodejs', fileName: 'nodejs.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

await agent.writeFile("/home/agentos/demo.mjs", \`
import fs from "fs";

fs.mkdirSync("/home/agentos/project/src", { recursive: true });
fs.writeFileSync("/home/agentos/project/src/index.js", 'console.log("hello");');

const files = fs.readdirSync("/home/agentos/project", { recursive: true });
console.log("Files:", files);
\`);

const result = await agent.exec("node /home/agentos/demo.mjs");
console.log(result.stdout);` },

	{ key: 'bash', fileName: 'bash.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

// Write a script to back up the working directory
await agent.writeFile("/home/agentos/backup.sh", \`#!/bin/bash
set -e
mkdir -p /home/agentos/backups
tar -czf /home/agentos/backups/backup_$(date +%s).tar.gz -C /home/agentos/project .
echo "Done:" && ls -lh /home/agentos/backups/
\`);

const result = await agent.exec("bash /home/agentos/backup.sh");
console.log(result.stdout);` },

	{ key: 's3-filesystem', fileName: 's3-filesystem.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";

// Mount an S3 bucket as a filesystem with the built-in "s3" plugin
const vm = agentOS({
  mounts: [
    {
      path: "/home/agentos/data",
      plugin: {
        id: "s3",
        config: { bucket: process.env.S3_BUCKET!, region: "us-east-1" },
      },
    },
  ],
});
export const registry = setup({ use: { vm } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

await agent.writeFile("/home/agentos/data/notes.txt", "Hello from agentOS!");
const content = await agent.readFile("/home/agentos/data/notes.txt");
console.log(new TextDecoder().decode(content));` },

	{ key: 'cron', fileName: 'cron.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

// Heartbeat: wake the agent every 30 minutes to check on issues
await agent.scheduleCron({
  schedule: "*/30 * * * *",
  action: {
    type: "session",
    agentType: "pi",
    prompt: "Check the status of open issues and take any necessary action",
  },
});` },

	{ key: 'webhooks', fileName: 'webhooks.ts', code: `import { Hono } from "hono";
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const app = new Hono();
const client = createClient<typeof registry>("http://localhost:6420");

app.post("/slack/events", async (c) => {
  const { team_id, text, user } = (await c.req.json()).event;

  // Each workspace gets its own persistent agent
  const agent = client.vm.getOrCreate([team_id]);
  const session = await agent.createSession("pi");
  await agent.sendPrompt(session.sessionId, \`Message from \${user}: \${text}\`);

  return c.json({ ok: true });
});` },

	{ key: 'multiplayer', fileName: 'multiplayer.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");

// Both clients connect to the same agent by key
const a = client.vm.getOrCreate("shared-agent").connect();
const b = client.vm.getOrCreate("shared-agent").connect();

// Both receive the same session events
a.on("sessionEvent", (e) => console.log("[A]", e.event.method));
b.on("sessionEvent", (e) => console.log("[B]", e.event.method));

// Either client can send prompts to the shared session
const session = await a.createSession("pi");
await a.sendPrompt(session.sessionId, "Build a REST API");` },

	{ key: 'workflows', fileName: 'workflows.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";
import { actor, queue } from "rivetkit";
import { workflow } from "rivetkit/workflow";
import pi from "@agentos-software/pi";

const vm = agentOS({ software: [pi] });

// Durable workflow: every ctx.step is recorded, retried, and resumed after a crash
const bugFixer = actor({
  queues: { fixBug: queue<{ repo: string; issue: string }>() },
  run: workflow(async (ctx) => {
    await ctx.loop("fix-bug-loop", async (loop) => {
      const { repo, issue } = (await loop.queue.next("wait-fix-bug")).body;
      const agent = loop.client<typeof registry>().vm.getOrCreate("bug-fixer");

      await loop.step("clone-repo", () => agent.exec(\`git clone \${repo} /home/agentos/repo\`));
      await loop.step("fix-bug", async () => {
        const session = await agent.createSession("pi");
        await agent.sendPrompt(session.sessionId, \`Fix: \${issue}\`);
        await agent.closeSession(session.sessionId);
      });
      await loop.step("run-tests", () => agent.exec("cd /home/agentos/repo && npm test"));
    });
  }),
});

export const registry = setup({ use: { bugFixer, vm } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const handle = client.bugFixer.getOrCreate("main");

// Trigger the durable workflow; it survives restarts and resumes mid-run
await handle.send("fixBug", {
  repo: "https://github.com/example/repo.git",
  issue: "Fix the login redirect bug",
});` },

	{ key: 'git', fileName: 'git.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

// Initialize a repo, commit, and branch
await agent.exec("git init /home/agentos/repo");
await agent.writeFile("/home/agentos/repo/README.md", "# My Project");
await agent.exec("git -C /home/agentos/repo add README.md");
await agent.exec("git -C /home/agentos/repo commit -m 'initial commit'");

// Create a feature branch
await agent.exec("git -C /home/agentos/repo checkout -b feature");
await agent.writeFile("/home/agentos/repo/feature.txt", "new feature");
await agent.exec("git -C /home/agentos/repo add feature.txt");
await agent.exec("git -C /home/agentos/repo commit -m 'add feature'");

const content = await agent.readFile("/home/agentos/repo/feature.txt");
console.log(new TextDecoder().decode(content));` },

	{ key: 'sandbox', fileName: 'sandbox.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";
import { createSandboxFs, createSandboxBindings } from "@rivet-dev/agentos-sandbox";
import { SandboxAgent } from "sandbox-agent";
import { docker } from "sandbox-agent/docker";

// Start a Docker-backed sandbox
const sandbox = await SandboxAgent.start({ sandbox: docker() });

// Mount its filesystem and register the sandbox bindings
const vm = agentOS({
  mounts: [{ path: "/home/agentos/sandbox", plugin: createSandboxFs({ client: sandbox }) }],
  bindings: [createSandboxBindings({ client: sandbox })],
});
export const registry = setup({ use: { vm } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent");

// Write a file through the mounted sandbox filesystem
await agent.writeFile("/home/agentos/sandbox/hello.txt", "Hello from agentOS!");
const content = await agent.readFile("/home/agentos/sandbox/hello.txt");
console.log(new TextDecoder().decode(content));

// Run a command inside the Docker sandbox via the mounted toolkit
const result = await agent.exec("agentos-sandbox run-command --command echo --json '{\\"args\\": [\\"hello from Docker\\"]}'");
console.log(result.stdout);` },

	{ key: 'permissions', fileName: 'permissions.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>("http://localhost:6420");
const agent = client.vm.getOrCreate("my-agent").connect();

// Human-in-the-loop: respond to permission requests as they arrive
agent.on("permissionRequest", async ({ sessionId, request }) => {
  const description = (request.description ?? "").toLowerCase();

  // Allow read-only operations automatically
  if (description.includes("read")) {
    await agent.respondPermission(sessionId, request.permissionId, "always");
    return;
  }

  // Deny dangerous operations
  if (description.includes("rm -rf")) {
    await agent.respondPermission(sessionId, request.permissionId, "reject");
    return;
  }

  // Approve everything else once — "once" | "always" | "reject"
  await agent.respondPermission(sessionId, request.permissionId, "once");
});` },
];

const heroTabs = await Promise.all(
	heroTabSnippets.map(async (tab) => ({
		...tab,
		highlightedCode: await highlightCodeHtml(tab.code, 'ts'),
	})),
);
---

<Layout
  title="agentOS — A faster, lighter, cheaper alternative to sandboxes"
  description="A portable open-source operating system for agents. Stateful runtime, universal agent interface, and secure code execution. One SDK, deploy anywhere."
  ogImage="https://agentos-sdk.dev/og.png"
>
  <Navigation revealLogoOnScroll client:load />
  <AgentOSPage heroTabs={heroTabs} client:load />
  <Footer client:visible />
</Layout>
