---
import Layout from "../layouts/Layout.astro";
import { Navigation } from "../components/Navigation";
import { Footer } from "../components/Footer";
import AgentOSPage, { FILESYSTEM_CODE } from "../components/marketing/solutions/AgentOSPage";
import { highlightCodeHtml } from "../lib/highlight-code";

const heroTabSnippets = [
	{ key: 'cron', fileName: 'agent-loop.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>({ endpoint: "http://localhost:6420" });
const agent = client.vm.getOrCreate("my-agent");

// Wake the agent every five minutes, run one turn, then sleep again.
await agent.scheduleCron({
  schedule: "*/5 * * * *",
  overlap: "skip",
  action: {
    type: "session",
    agentType: "pi",
    prompt: "Check for new work and process the next task",
  },
});` },

	{ key: 'agent-agent', fileName: 'agent-agent.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";
import { createClient } from "@rivet-dev/agentos/client";
import pi from "@agentos-software/pi";
import { z } from "zod";

// The reviewer is its own isolated agent VM
const reviewer = agentOS({ software: [pi] });

// Bridge: copy a file from the writer's VM to the reviewer's, then review it
async function reviewFile(path: string) {
  const client = createClient<typeof registry>({ endpoint: "http://localhost:6420" });
  const writer = client.writer.getOrCreate("my-project");
  const reviewerHandle = client.reviewer.getOrCreate("my-project");

  const code = await writer.readFile(path);
  await reviewerHandle.writeFile(path, code);

  await reviewerHandle.openSession({
    agent: "pi",
    env: { ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY! },
  });
  try {
    const result = await reviewerHandle.prompt({
      content: [{ type: "text", text: \`Review \${path}\` }],
    });
    return result.message?.content
      .filter((block) => block.type === "text")
      .map((block) => block.text)
      .join("") ?? "";
  } finally {
    await reviewerHandle.deleteSession();
  }
}

// The writer gets a "review" binding -> agentos-review submit --path ...
const writer = agentOS({
  software: [pi],
  bindings: [{
    name: "review",
    description: "Send code to the reviewer agent",
    bindings: {
      submit: {
        description: "Submit a file for code review",
        inputSchema: z.object({ path: z.string().describe("Path to the file") }),
        execute: async ({ path }: { path: string }) => ({ review: await reviewFile(path) }),
      },
    },
  }],
});

export const registry = setup({ use: { writer, reviewer } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>({ endpoint: "http://localhost:6420" });
const writer = client.writer.getOrCreate("my-project");

await writer.openSession({
  agent: "pi",
  env: { ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY! },
});
await writer.prompt({
  content: [{ type: "text", text: "Write a REST API at /home/agentos/api.ts, then run agentos-review submit --path /home/agentos/api.ts" }],
});` },

	{ key: 'multiplayer', fileName: 'multiplayer.ts', code: `import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const aliceClient = createClient<typeof registry>({ endpoint: "http://localhost:6420" });
const bobClient = createClient<typeof registry>({ endpoint: "http://localhost:6420" });

// Two clients connect to the same agent by key.
const alice = aliceClient.vm.getOrCreate("shared-agent").connect();
const bob = bobClient.vm.getOrCreate("shared-agent").connect();

// Both receive the same session events.
alice.on("sessionEvent", (event) => console.log("[Alice]", event));
bob.on("sessionEvent", (event) => console.log("[Bob]", event));

// Either client can act on the shared session.
await alice.openSession({
  agent: "pi",
  env: { ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY! },
});
await bob.prompt({
  content: [{ type: "text", text: "Build a REST API" }],
});` },

	{ key: 'workflows', fileName: 'workflow.ts', code: `// server.ts
import { agentOS, setup } from "@rivet-dev/agentos";
import pi from "@agentos-software/pi";
import { actor, queue } from "rivetkit";
import { workflow } from "rivetkit/workflow";

const vm = agentOS({ software: [pi] });

const codeReview = actor({
  state: { status: "pending" },
  queues: {
    review: queue<{ approved: boolean; feedback?: string }>(),
  },
  run: workflow(async (ctx) => {
    let feedback = "";

    for (let revision = 1; revision <= 3; revision++) {
      await ctx.step({
        name: \`write-code-\${revision}\`,
        maxRetries: 3,
        run: async (step) => {
          const agent = step.client<typeof registry>().vm.getOrCreate("writer");
          const sessionId = \`revision-\${revision}\`;
          await agent.openSession({
            sessionId,
            agent: "pi",
            env: { ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY! },
          });
          try {
            await agent.prompt({
              sessionId,
              content: [{ type: "text", text: \`Write the change. Review feedback: \${feedback}\` }],
            });
          } finally {
            await agent.deleteSession({ sessionId });
          }
        },
      });

      // The workflow sleeps durably until your app approves or rejects it.
      const review = await ctx.queue.next(\`review-\${revision}\`);
      if (review.body.approved) {
        await ctx.step("approve", async (step) => {
          step.state.status = "approved";
        });
        return;
      }
      feedback = review.body.feedback ?? "Revise and retry";
    }

    throw new Error("Review rejected after 3 revisions");
  }),
});

export const registry = setup({ use: { vm, codeReview } });
registry.start();

// client.ts
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>({ endpoint: "http://localhost:6420" });
const review = client.codeReview.getOrCreate("change-42");
await review.send("review", { approved: true });` },

	{ key: 'human-in-the-loop', fileName: 'approvals.ts', code: `import { createInterface } from "node:readline/promises";
import { createClient } from "@rivet-dev/agentos/client";
import type { registry } from "./server";

const client = createClient<typeof registry>({ endpoint: "http://localhost:6420" });
const agent = client.vm.getOrCreate("my-agent");
const terminal = createInterface({ input: process.stdin, output: process.stdout });

// Permission requests arrive on the durable session event stream.
const connection = agent.connect();
connection.on("sessionEvent", (event) => {
  if (event.type !== "permission_request") return;

  // Replace this terminal prompt with your application's approval UI.
  void (async () => {
    console.log("Tool call:", event.toolCall);
    const answer = await terminal.question("Approve once? [y/N] ");
    const accepted = answer.trim().toLowerCase() === "y";
    const kinds = accepted
      ? ["allow_once", "allow_always"]
      : ["reject_once", "reject_always"];
    const option = event.options.find((candidate) => kinds.includes(candidate.kind));
    if (!option) throw new Error("The agent did not offer a compatible decision");

    await agent.respondPermission({
      sessionId: event.sessionId,
      requestId: event.requestId,
      optionId: option.optionId,
    });
  })().catch((error) => console.error("Permission response failed:", error));
});

await agent.openSession({
  agent: "pi",
  permissionPolicy: "ask",
  env: { ANTHROPIC_API_KEY: process.env.ANTHROPIC_API_KEY! },
});
try {
  await agent.prompt({
    content: [{ type: "text", text: "Create /workspace/output.txt" }],
  });
} finally {
  terminal.close();
}` },
];

const heroTabs = await Promise.all(
	heroTabSnippets.map(async (tab) => ({
		...tab,
		highlightedCode: await highlightCodeHtml(tab.code, 'ts'),
	})),
);
const filesystemHighlightedCode = await highlightCodeHtml(FILESYSTEM_CODE, 'ts');
---

<Layout
  title="agentOS — Virtual operating system for agents"
  description="A virtual operating system for agents, with filesystem, execution, and orchestration in one lightweight library."
  ogImage="https://agentos-sdk.dev/og.png"
>
  <Navigation revealLogoOnScroll client:load />
  <AgentOSPage heroTabs={heroTabs} filesystemHighlightedCode={filesystemHighlightedCode} client:load />
  <Footer client:visible />
</Layout>
