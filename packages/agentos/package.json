{
	"name": "@rivet-dev/agentos",
	"version": "0.0.1",
	"description": "A native TypeScript RivetKit actor backed by the AgentOS core SDK and sidecar.",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"agent-os",
		"agentos",
		"agents",
		"actors",
		"ai"
	],
	"sideEffects": false,
	"files": [
		"dist",
		"assets",
		"package.json",
		"README.md"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./client": {
			"import": {
				"browser": {
					"types": "./dist/client.d.ts",
					"default": "./dist/client.js"
				},
				"types": "./dist/client.d.ts",
				"default": "./dist/client.js"
			}
		},
		"./react": {
			"import": {
				"types": "./dist/react.d.ts",
				"default": "./dist/react.js"
			}
		}
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "pnpm build:actor && pnpm build:tabs",
		"build:actor": "tsup src/index.ts src/client.ts src/react.ts",
		"build:tabs": "vite build --config vite.tabs.config.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "cargo build --manifest-path ../../Cargo.toml -p agentos-sidecar && pnpm --filter @rivet-dev/agentos-runtime-core build && pnpm --filter @agentos-software/manifest build && pnpm --filter @agentos-software/common... build && pnpm --filter @agentos-software/coreutils build:runtime && pnpm --filter @rivet-dev/agentos-test-harness build && pnpm --filter @rivet-dev/agentos-core build && pnpm build && pnpm test:e2e:run",
		"test:e2e:run": "AGENTOS_ACTOR_E2E=1 vitest run tests/actor.e2e.test.ts tests/agent-os-conformance.e2e.test.ts --fileParallelism=false"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "0.16.1",
		"@agentos-software/common": "workspace:*",
		"@rivet-dev/agentos-core": "workspace:*",
		"@rivetkit/react": "catalog:rivetkit",
		"rivetkit": "catalog:rivetkit",
		"zod": "^4.1.11"
	},
	"peerDependencies": {
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@rivet-dev/agentos-test-harness": "workspace:*",
		"@radix-ui/react-collapsible": "^1.1.2",
		"@radix-ui/react-scroll-area": "^1.2.2",
		"@tanstack/react-query": "^5.87.1",
		"@types/node": "^22.19.15",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"postcss": "^8.4.49",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwind-merge": "^2.6.0",
		"tailwindcss": "^3.4.17",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vite": "^5.4.20",
		"vitest": "^2.1.8"
	}
}
