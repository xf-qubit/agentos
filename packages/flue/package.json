{
	"name": "@rivet-dev/agentos-flue",
	"version": "0.0.1",
	"description": "agentOS sandbox adapter for Flue",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "AGENTOS_ACTOR_E2E=1 vitest run tests/actor-e2e.test.ts"
	},
	"peerDependencies": {
		"@flue/runtime": ">=1.0.0-beta.9 <2",
		"@rivet-dev/agentos": ">=0.0.1",
		"@rivet-dev/agentos-core": ">=0.0.1"
	},
	"peerDependenciesMeta": {
		"@rivet-dev/agentos": {
			"optional": true
		},
		"@rivet-dev/agentos-core": {
			"optional": true
		}
	},
	"devDependencies": {
		"@flue/runtime": "npm:@rivet-dev/labs-flue-runtime@1.0.0-beta.9-rivet.1",
		"@rivet-dev/agentos": "workspace:*",
		"@rivet-dev/agentos-core": "workspace:*",
		"@types/node": "^24.0.0",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
