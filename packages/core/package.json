			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./internal/runtime-compat": {
			"types": "./dist/runtime-compat.d.ts",
			"import": "./dist/runtime-compat.js",
			"default": "./dist/runtime-compat.js"
		},
		"./test/file-system": {
			"types": "./dist/test/file-system.d.ts",
			"import": "./dist/test/file-system.js",
			"default": "./dist/test/file-system.js"
		},
		"./test/docker": {
