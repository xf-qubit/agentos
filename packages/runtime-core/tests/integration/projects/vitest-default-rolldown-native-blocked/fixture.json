{
  "entry": "node_modules/vitest/vitest.mjs",
  "args": [
    "run",
    "--config=vitest.config.mjs",
    "--pool=forks",
    "--maxWorkers=1",
    "--no-file-parallelism",
    "--reporter=json",
    "--outputFile=vitest-report.json"
