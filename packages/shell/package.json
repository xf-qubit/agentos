{
  "name": "@rivet-dev/agent-os-shell",
  "private": true,
  "type": "module",
  "bin": {
    "agent-os-shell": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "shell": "tsx src/main.ts",
    "test": "pnpm build && vitest run --fileParallelism=false"
  },
  "dependencies": {
    "@rivet-dev/agent-os-core": "workspace:*",
    "@agent-os-pkgs/common": "catalog:",
    "@agent-os-pkgs/jq": "catalog:",
    "@agent-os-pkgs/ripgrep": "catalog:",
    "@agent-os-pkgs/fd": "catalog:",
    "@agent-os-pkgs/tree": "catalog:",
    "@agent-os-pkgs/file": "catalog:",
    "@agent-os-pkgs/zip": "catalog:",
    "@agent-os-pkgs/unzip": "catalog:",
    "@agent-os-pkgs/yq": "catalog:",
    "@agent-os-pkgs/codex": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
